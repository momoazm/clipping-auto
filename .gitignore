# secrets / env (provided at runtime via GitHub Actions secrets)
API.env
.env
credentials.json
token.json
token.*.json
cookies.txt
# python
.venv/
__pycache__/
*.pyc
# scratch + media (regenerated every run, never committed)
.tmp/
*.eml
*.mp4
*.mov
*.mkv
*.webm
*.ass
*.srt
# SFX / music beds are regenerated by build_sfx.py / build_music.py (CI + local)
config/sfx/*.wav
config/music/*.mp3
!config/sfx/README.md
!config/music/README.md

# NOTE: unlike the working clipping/, this standalone automation repo intentionally
# COMMITS the YuNet model (config/models/*.onnx) and the Anton font (brand/fonts/*.ttf)
# so GitHub Actions has them at runtime. state/clipped_history.json is committed too
# (it's the no-repeat memory the workflow pushes back after each run).
